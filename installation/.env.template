# ============================================
# World Monitor — Environment Configuration
# ============================================
# This is a simplified template for quick setup.
# For detailed documentation, see API_KEYS_GUIDE.md
#
# Copy this file to .env.local and fill in your keys:
#   cp installation/.env.template .env.local
#
# ============================================

# ------ ESSENTIAL (Start Here) ------

# AI Summarization (choose at least one)
GROQ_API_KEY=                           # Get at: https://console.groq.com/ (14,400 req/day free)
OPENROUTER_API_KEY=                     # Get at: https://openrouter.ai/ (50 req/day free, fallback)

# Caching (highly recommended for performance)
UPSTASH_REDIS_REST_URL=                 # Get at: https://upstash.com/ (10K commands/day free)
UPSTASH_REDIS_REST_TOKEN=

# Conflict Data (core geopolitical feature)
ACLED_ACCESS_TOKEN=                     # Get at: https://acleddata.com/ (free for researchers)


# ------ RECOMMENDED (Enhanced Features) ------

# Market Data
FINNHUB_API_KEY=                        # Get at: https://finnhub.io/ (free tier)

# Energy & Economic Data
EIA_API_KEY=                            # Get at: https://www.eia.gov/opendata/ (free)
FRED_API_KEY=                           # Get at: https://fred.stlouisfed.org/docs/api/api_key.html (free)

# Satellite Fire Detection
NASA_FIRMS_API_KEY=                     # Get at: https://firms.modaps.eosdis.nasa.gov/ (free)

# Internet Outages
CLOUDFLARE_API_TOKEN=                   # Cloudflare account + Radar access (free)

# Additional Conflict Data
UCDP_ACCESS_TOKEN=                      # Get at: https://ucdp.uu.se/apidocs/ (free)


# ------ OPTIONAL (Specialized Features) ------

# Aviation Intelligence
AVIATIONSTACK_API=                      # Get at: https://aviationstack.com/
ICAO_API_KEY=                           # Get at: https://applications.icao.int/
TRAVELPAYOUTS_API_TOKEN=                # Get at: https://www.travelpayouts.com/

# Aircraft & Vessel Tracking
WINGBITS_API_KEY=                       # Get at: https://wingbits.com/
AISSTREAM_API_KEY=                      # Get at: https://aisstream.io/ (for Railway relay)
OPENSKY_CLIENT_ID=                      # Get at: https://opensky-network.org/
OPENSKY_CLIENT_SECRET=


# ------ RAILWAY RELAY (Optional) ------
# Required for: AIS vessel tracking, OpenSky aircraft, Telegram OSINT, OREF alerts

WS_RELAY_URL=                           # Your Railway deployment URL (https://)
VITE_WS_RELAY_URL=                      # Your Railway deployment URL (wss://)
RELAY_SHARED_SECRET=                    # Generate with: openssl rand -hex 32
RELAY_AUTH_HEADER=x-relay-key
ALLOW_UNAUTHENTICATED_RELAY=false
RELAY_METRICS_WINDOW_SECONDS=60


# ------ TELEGRAM OSINT (Optional, requires Railway relay) ------

TELEGRAM_API_ID=                        # Get at: https://my.telegram.org/apps
TELEGRAM_API_HASH=
TELEGRAM_SESSION=                       # Generate with: node scripts/telegram/session-auth.mjs
TELEGRAM_CHANNEL_SET=full               # Options: full, tech, finance


# ------ SITE CONFIGURATION ------

# Site variant
VITE_VARIANT=full                       # Options: full, tech, finance, commodity, happy

# API base URL (leave empty for same-domain)
VITE_WS_API_URL=

# Error tracking (optional)
VITE_SENTRY_DSN=

# Map interaction mode
VITE_MAP_INTERACTION_MODE=3d            # Options: 3d, flat

# Self-hosted map tiles (optional)
VITE_PMTILES_URL=
VITE_PMTILES_URL_PUBLIC=


# ------ DESKTOP APP (Optional) ------

# Cloud fallback API keys (comma-separated)
WORLDMONITOR_VALID_KEYS=


# ------ REGISTRATION DATABASE (Optional) ------

# Convex deployment URL
CONVEX_URL=                             # Get at: https://dashboard.convex.dev/


# ------ LOCAL AI (Optional, no API keys needed) ------

# Ollama configuration (runs AI locally)
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b


# ============================================
# NOTES:
# - All keys are optional - dashboard works without them
# - Start with ESSENTIAL section for core features
# - Add RECOMMENDED for full experience
# - See API_KEYS_GUIDE.md for detailed documentation
# ============================================
